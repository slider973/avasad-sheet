############
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# Generate secrets with: openssl rand -hex 32
############

# PostgreSQL
POSTGRES_PASSWORD=change-me
POSTGRES_USER=supabase_admin
POSTGRES_DB=supabase
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Supabase JWT - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-super-secret-jwt-token-with-at-least-32-characters
# Generate ANON_KEY and SERVICE_ROLE_KEY from JWT_SECRET using:
# https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
ANON_KEY=change-me
SERVICE_ROLE_KEY=change-me

# Public URLs (change to your domain)
SITE_URL=https://timesheet.yourdomain.ch
API_EXTERNAL_URL=https://api.timesheet.yourdomain.ch
SUPABASE_PUBLIC_URL=https://api.timesheet.yourdomain.ch

# Studio
STUDIO_PORT=3000
STUDIO_DEFAULT_ORGANIZATION=TimeSheet
STUDIO_DEFAULT_PROJECT=Time Sheet

# Auth / GoTrue
GOTRUE_SITE_URL=https://timesheet.yourdomain.ch
GOTRUE_URI_ALLOW_LIST=
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=false
GOTRUE_SMTP_HOST=smtp.example.com
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_SENDER_NAME=TimeSheet
GOTRUE_SMTP_ADMIN_EMAIL=admin@yourdomain.ch

# Google OAuth
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=https://api.timesheet.yourdomain.ch/auth/v1/callback

# Storage
STORAGE_BACKEND=file
STORAGE_FILE_BACKEND_PATH=/var/lib/storage

# Realtime
REALTIME_DB_HOST=db

# PowerSync
POWERSYNC_PORT=8080
POWERSYNC_DB_HOST=db
POWERSYNC_DB_PORT=5432
POWERSYNC_DB_NAME=supabase
POWERSYNC_DB_USER=supabase_admin
POWERSYNC_DB_PASSWORD=change-me

# Nginx / SSL
DOMAIN=timesheet.yourdomain.ch
ACME_EMAIL=admin@yourdomain.ch
