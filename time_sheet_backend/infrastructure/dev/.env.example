# Environnement DEV — copier vers .env et remplir. NE JAMAIS COMMITTER .env.
# Générer JWT_SECRET : openssl rand -hex 32
# Générer ANON_KEY / SERVICE_ROLE_KEY : JWT HS256 signés avec JWT_SECRET
#   (payload {"role":"anon"|"service_role","iss":"supabase","iat":...,"exp":...})

POSTGRES_PASSWORD=change-me
POSTGRES_USER=supabase_admin
POSTGRES_DB=supabase
POSTGRES_HOST=dev-db
POSTGRES_PORT=5432

JWT_SECRET=change-me
ANON_KEY=change-me
SERVICE_ROLE_KEY=change-me

SITE_URL=https://dev.timesheet.example.com
API_EXTERNAL_URL=https://dev-supabase.timesheet.example.com
SUPABASE_PUBLIC_URL=https://dev-supabase.timesheet.example.com
GOTRUE_SITE_URL=https://dev.timesheet.example.com
GOTRUE_URI_ALLOW_LIST=
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=true

GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_SENDER_NAME=
GOTRUE_SMTP_ADMIN_EMAIL=

GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=

STORAGE_BACKEND=file
STORAGE_FILE_BACKEND_PATH=/var/lib/storage

POWERSYNC_PORT=8080
POWERSYNC_DB_HOST=dev-db
POWERSYNC_DB_PORT=5432
POWERSYNC_DB_NAME=supabase
POWERSYNC_DB_USER=supabase_admin
POWERSYNC_DB_PASSWORD=change-me
