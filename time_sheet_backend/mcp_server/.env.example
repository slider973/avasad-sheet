# Port d'écoute du serveur MCP (interne au container)
PORT=8787

# Fuseau horaire utilisé pour formater day_date et HH:mm
TIMEZONE=Europe/Zurich

# URL interne de l'API Supabase (depuis le container Dokploy).
# En self-hosted depuis Dokploy, utilise l'URL réseau interne du Kong, par ex. :
#   http://kong:8000
# ou l'URL publique :
#   https://api.timesheet.staticflow.ch
SUPABASE_URL=https://api.timesheet.staticflow.ch

# Clé service-role (Supabase Studio → Project Settings → API → service_role).
# NE JAMAIS commiter cette valeur.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
