# Clé API App Store Connect pour fastlane (uploads non-interactifs, sans 2FA)
# Copier ce fichier en `.env` (non versionné) et renseigner les 3 valeurs.
#
# Où trouver ces valeurs : App Store Connect > Users and Access > Integrations >
#   App Store Connect API (compte/team de l'app, ici Team CSQ565C7YY).
#   - ASC_ISSUER_ID : "Issuer ID" affiché en haut de la page
#   - ASC_KEY_ID    : colonne "KEY ID" de la clé (ou nom de fichier AuthKey_<KEY_ID>.p8)
#   - le fichier .p8 se télécharge UNE seule fois à la création de la clé.

ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
ASC_KEY_FILEPATH=/Users/jonathanlemaine/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8
